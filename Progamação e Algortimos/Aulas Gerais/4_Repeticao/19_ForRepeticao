const prompt = require('readline-sync');

//Escolher o numero que deseja fazer a tabuada
let valorTabuada = Number(prompt.question("Digite o número da tabuada que deseja criar:"));

//Multiplicar pelos valores de 0 (Inicio) a 10 (Fim)
for(let i = 0; i <= 10; i++){
//Recuperar os resultados
    console.log(`${i} x ${valorTabuada} = ${i*valorTabuada}`);
}


